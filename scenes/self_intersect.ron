        (
            name: "common",
            data: (("bool invert_if(bool value, bool condition) {
  if (condition) {
    return !value;
  } else {
    return value;
  }
}")),
        ),
        (
            name: "room",
            data: (("int is_inside_square(float x, float y, float sizex, float sizey, int material) {
  if (abs(x) < sizex && abs(y) < sizey) {
    return material;
  } else {
    return NOT_INSIDE;
  }
}
")),
        ),
        (
            name: "box",
            data: (("SceneIntersection intersect_box(Ray r, int material) {
vec3 rad = vec3(4., 4., 4.);
vec3 m = 1.0/r.d.xyz;
vec3 n = m*r.o.xyz;
vec3 k = abs(m)*rad;
vec3 t1 = -n - k;
vec3 t2 = -n + k;

float tN = max( max( t1.x, t1.y ), t1.z );
float tF = min( min( t2.x, t2.y ), t2.z );

float t = tN;
if (tN < 0.0 && tF > 0.0) t = tF;

if(tN > tF) return scene_intersection_none;

if(t < 0.0) return scene_intersection_none;

vec3 oN = -sign(r.d.xyz)*step(t1.yzx,t1.xyz)*step(t1.zxy,t1.xyz);

vec3 pos = (r.o + r.d * t).xyz;

vec2 uv = vec2(pos.x, pos.y);
if (abs(abs(pos.x) - rad.x) < 0.0001) {
  uv = vec2(pos.y, pos.z);
}
if (abs(abs(pos.y) - rad.y) < 0.0001) {
  uv = vec2(pos.x, pos.z);
}

return SceneIntersection(material, SurfaceIntersection(true, t, uv.x, uv.y, normalize_normal(r.d.xyz, oN)), false);
}")),
        ),
        (
            name: "portal",
            data: (("float circle_distance(float x, float y) {
  return sqrt(sqr(x) + sqr(y));
}

float ellipse_distance(float x, float y) {
  return sqrt(2.*sqr(x) + sqr(y));
}

float square_distance(float x, float y) {
  return max(abs(x), abs(y));
}

float rect_distance(float x, float y, float a, float b) {
  return max(abs(x)-a+1., abs(y)-b+1.);
}

float triangle_distance(float x, float y, float k1, float k2, float y1) {
  return max(
    (y-k1*x)/sqrt(1.0+sqr(k1)),
  max(
    (y-k2*x)/sqrt(1.0+sqr(k2)),
    -y1 * y
  ));
}

int is_inside_object(
  float distance, 
  float size, 
  float border,
  int material_inner, 
  int material_border
) {
  if (distance < size) return material_inner;
  if (distance < size + border) return material_border;
  return NOT_INSIDE;
}

int is_inside_portal(
  float distance, 
  float size, 
  float border,
  float black_border,
  int material_first, 
  int material_second, 
  int grid_material_first, 
  int grid_material_second, 
  bool back,
  bool first
) {
  int material = material_second;
  if (first) { material = material_first; }

  if (distance < size) {
    if (back) {
      return material;      
    } else {
      if (teleport_light_u == 1) {
      	if (mirror_u == 1) {
          return mirror_M;
        } else {
          return TELEPORT;
        }
      } else {
        if (first) {
          return grid_material_first;
        } else {
          return grid_material_second;
        }
      }
    }
  }
  int black_material = solid_black_M;
  if (_black_border_disable == 1) black_material = material;
  if (distance < size + black_border && !back) return black_material;
  if (distance < size + black_border + border) return material;
  if (distance < size + black_border + border + black_border) return black_material;

  return NOT_INSIDE;
}")),
        ),
        (
            name: "cylinder",
            data: (("SceneIntersection intersect_cylinder_portal_v2(
  float cylinder_radius,
  float border_size,
  float black_border_size,
  float cylinder_height,
  Ray r,
  bool first
) {
  float a = dot(r.d.xy, r.d.xy);
  float b = 2.0 * dot(r.o.xy, r.d.xy);
  float c = dot(r.o.xy, r.o.xy) - sqr(cylinder_radius);
  float det = b*b - 4.0 * a * c;
  if (det < 0.) return scene_intersection_none;

  det = sqrt(det);

  float t = (-b - det)/(2.*a);
  vec4 pos = r.o + r.d * t;
  float u = atan(pos.y, pos.x) * cylinder_radius;
  float v = pos.z;
  float distance = rect_distance(u, v, PI*cylinder_radius, cylinder_height);
  int result_material = is_inside_portal(
    distance,
    1.0,
    border_size,
    black_border_size,
    portal_blue_M,
    portal_orange_M,
    grid_gray_M,
    grid_gray_M,
    two_sided_u == 0 && invert_if(false, first),
    first
  );
  if (u > 0.) result_material = NOT_INSIDE;

  if (t < 0. || result_material == NOT_INSIDE) {
    t = (-b + det)/(2.*a);
    pos = r.o + r.d * t;
    u = atan(pos.y, pos.x) * cylinder_radius;
    v = pos.z;
    distance = rect_distance(u, v, PI*cylinder_radius, cylinder_height);
    result_material = is_inside_portal(
      distance,
      1.0,
      border_size,
      black_border_size,
      portal_blue_M,
      portal_orange_M,
      grid_gray_M,
      grid_gray_M,
      two_sided_u == 0 && invert_if(true, first),
      first
    );
    if (u > 0.) result_material = NOT_INSIDE;
    if (t< 0. || result_material == NOT_INSIDE) {
      return scene_intersection_none;
    }
  }

  vec3 n = normalize(vec3(pos.xy, 0.));

  return SceneIntersection(result_material, SurfaceIntersection(true, t, u, v, n), false);
}
")),
