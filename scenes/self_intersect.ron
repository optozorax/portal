        (
            name: "half-sphere",
            data: Complex(
                kind: Portal(Some(Named("a")), Some(Named("b"))),
                intersect: (("vec3 op = -r.o.xyz;
float b = dot(op, r.d.xyz);
float det = b*b - dot(op, op) + 1.0;
if (det < 0.) return scene_intersection_none;

det = sqrt(det);
float t = b - det;
vec4 pos = r.o + r.d * t;
if (pos.z > 0. || t < 0. || pos.x > a_u) t = b + det;
pos = r.o + r.d * t;
if (pos.z > 0. || t < 0. || pos.x > a_u) return scene_intersection_none;

vec3 n = normalize(pos.xyz);

float u = atan(pos.z, pos.x);
float v = atan(sqrt(pos.x * pos.x + pos.z * pos.z), pos.y);

int material = TELEPORT;
if (teleport_light_u == 0) material = grid_gray_M;

if (two_sided_u == 0) {
if ((first && dot(n, r.d.xyz) < 0.) || (!first && dot(n, r.d.xyz) > 0.)) {
if (first) { material = portal_blue_M;
} else { material = portal_orange_M; }
}
}

return SceneIntersection(material, SurfaceIntersection(true, t, u, v, n), false);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "border",
            data: Flat(
                kind: Portal(Some(Named("a")), Some(Named("b"))),
                is_inside: (("if (x > a_u + black_border_u) return NOT_INSIDE;

float distance = circle_distance(x, y);
if (distance < 1. + 2.*black_border_u + border_u && x > a_u && sqr(y) > 1.-a_u*a_u) return solid_black_M;
if (x > a_u) return NOT_INSIDE;
if (distance < 1.) distance = 2.;
int result = is_inside_portal(
  distance,
  1.0,
  border_u,
  black_border_u,
  portal_blue_M,
  portal_orange_M,
  grid_gray_M,
  grid_gray_M,
  false,
  first
);
if (result == TELEPORT) return NOT_INSIDE;

return result;")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "circle",
            data: Flat(
                kind: Portal(Some(Inline(Mul(
                    to: Some(Named("circle")),
                    what: Some(Named("a")),
                ))), Some(Inline(Mul(
                    to: Some(Named("circle")),
                    what: Some(Named("b")),
                )))),
                is_inside: (("int material = NOT_INSIDE;
if (first) { material = portal_blue_M;
} else { material = portal_orange_M; }

float height = sqrt(1.-a_u*a_u);

if (x*x + y*y < sqr(height) && x > 0.) {
  if (two_sided_u == 1 || ((back && first) || (back && !first))) {
    if (teleport_light_u == 1) {
      return TELEPORT;
    } else {
      return grid_gray_M;
    }
  } else {
    return material;
  }
} else {
  return NOT_INSIDE;
}")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "cylinder",
            data: Complex(
                kind: Portal(Some(Inline(Mul(
                    to: Some(Named("cylinder")),
                    what: Some(Named("a")),
                ))), Some(Inline(Mul(
                    to: Some(Named("cylinder")),
                    what: Some(Named("b")),
                )))),
                intersect: (("return intersect_cylinder_portal_v2(
  b_u,
  border_u,
  black_border_u,
  sqrt(1.-a_u*a_u),
  r,
  first
);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "circle2",
            data: Flat(
                kind: Portal(Some(Inline(Mul(
                    to: Some(Named("circle2")),
                    what: Some(Named("a")),
                ))), Some(Inline(Mul(
                    to: Some(Named("circle2")),
                    what: Some(Named("b")),
                )))),
                is_inside: (("x = -x;
if (x < 0.) return NOT_INSIDE;

x -= c_u;
if (x < 0.) x = 0.;

float height = sqrt(1.-a_u*a_u);

float distance = circle_distance(x, y);
int result = is_inside_portal(
  distance,
  height,
  border_u,
  black_border_u,
  portal_blue_M,
  portal_orange_M,
  grid_gray_M,
  grid_gray_M,
  two_sided_u == 0 && !back,
  first
);

return result;")),
                in_subspace: Normal,
            ),
