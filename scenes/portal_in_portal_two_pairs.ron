                )))),
                is_inside: (("if (show_object_u == 0) return NOT_INSIDE;

if ((circle_b_mat_inv * pos).z > 0.) return NOT_INSIDE;

if ((triangle_b_teleported_mat_inv * pos).z > 0.) return NOT_INSIDE;

int material = triangle_white_M;
if (colorize_object_u == 1) material = solid_1_M;

return is_inside_object(
  square_distance(x, y), 
  0.5, 
  0.04,
  material, 
  triangle_black_M
);")),
                in_subspace: Normal,
