        (
            name: "circle portal",
            data: Flat(
                kind: Portal(Some(Named("circle_a")), Some(Named("circle_b"))),
                is_inside: (("return is_inside_portal(
  circle_distance(x, y), 
  1.2, 
  0.1,
  0.02,
  portal_blue_M, 
