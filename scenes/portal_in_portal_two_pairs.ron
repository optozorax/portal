        (
            name: "triangle_portal",
            data: Flat(
                kind: Portal(Some(Named("triangle_a")), Some(Named("triangle_b"))),
                is_inside: (("vec4 pos1 = pos;
if (first) { pos1 = triangle_a_to_triangle_b_mat_teleport * pos; }

if ((circle_a_mat_inv * pos1).z < 0.) return NOT_INSIDE;

return is_inside_portal(
  triangle_distance(x, y, 1.61, -1.61, 1.0), 
  0.5, 
  0.07,
  0.01,
  portal_orange_M, 
  portal_blue_M, 
  solid_0_M, 
  solid_0_M, 
  back,
  first
);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "triangle_portal_teleported",
            data: Flat(
                kind: Portal(Some(Named("triangle_a")), Some(Named("triangle_b_teleported"))),
                is_inside: (("vec4 pos1 = pos;
if (first) { pos1 = triangle_a_to_triangle_b_mat_teleport * pos; }

if ((circle_b_mat_inv * pos1).z > 0.) return NOT_INSIDE;

return is_inside_portal(
  triangle_distance(x, y, 1.61, -1.61, 1.0), 
  0.5, 
  0.07,
  0.01,
  portal_orange_M, 
  portal_blue_M, 
  solid_1_M, 
  solid_1_M, 
  back,
  first
);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "object",
            data: Flat(
                kind: Simple(Some(Named("object"))),
                is_inside: (("if (show_object_u == 0) return NOT_INSIDE;

if ((triangle_a_mat_inv * pos).z < 0.) return NOT_INSIDE;

return is_inside_object(
  square_distance(x, y), 
  0.5, 
  0.04,
  triangle_white_M, 
  triangle_black_M
);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "object_teleported_red",
            data: Flat(
                kind: Simple(Some(Inline(Teleport(
                    first_portal: Some(Named("triangle_a")),
                    second_portal: Some(Named("triangle_b")),
                    what: Some(Named("object")),
                )))),
                is_inside: (("if (show_object_u == 0) return NOT_INSIDE;

if ((circle_a_mat_inv * pos).z < 0.) return NOT_INSIDE;

if ((triangle_b_mat_inv * pos).z > 0.) return NOT_INSIDE;

int material = triangle_white_M;
if (colorize_object_u == 1) material = solid_0_M;

return is_inside_object(
  square_distance(x, y), 
  0.5, 
  0.04,
  material, 
  triangle_black_M
);")),
                in_subspace: Normal,
            ),
