            name: "portal",
            data: Flat(
                kind: Portal(Some(Named("portal_a")), Some(Named("portal_b"))),
                is_inside: (("if ((portal_a_mat_inv * pos).z < 0.) {
if (!first) {
return NOT_INSIDE;
}
}

float width = 1.0;
float height = 2.0;
float border = 0.1;

if (abs(x) < width && abs(y) < height && !back) {
  if (first) {
    return grid_purple_M;
  } else {
    return grid_green_M;
  }
}

if (abs(x) < width + border && abs(y) < height + border) {
  if (!back) {
    if (abs(x) > width + 0.015 || abs(y) > height + 0.015 )
      if (first) {
        return portal_blue_black_M;
      } else {
        return portal_orange_black_M;
      }
    } else {
        if (first) {
          return portal_blue_black_M;
        } else {
          return portal_orange_black_M;
        }
    }
}

if (abs(x) < width + border + 0.015 && abs(y) < height + border + 0.015) {
  return solid_black_M;
}


return NOT_INSIDE;")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "triangle",
            data: Flat(
                kind: Simple(Some(Named("triangle"))),
                is_inside: (("if ((portal_a_mat_inv * pos).z < 0. && mirror_u == 0) return NOT_INSIDE;

return is_inside_triangle(x, y, 2.0, 2.0, 0.04, triangle_white_M, triangle_black_M);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "triangle_teleported",
