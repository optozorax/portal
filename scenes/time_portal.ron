                kind: Simple(Some(Named("triangle_teleported"))),
                is_inside: (("if ((portal_a_mat_inv * pos).z < 0. || mirror_u == 1) return NOT_INSIDE;

return is_inside_triangle(x, y, 2.0, 2.0, 0.04, triangle_white_M, triangle_black_M);")),
                in_subspace: Normal,
            ),
