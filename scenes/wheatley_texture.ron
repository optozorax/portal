    cameras: ([]),
    textures: ([]),
    materials: ([
        (
            name: "wheatley",
            data: Complex(
                code: (("return material_simple(hit, r, wheatley_color(hit.u, hit.v), 5e-1, false, 4e0, 3e-1);")),
            ),
        ),
