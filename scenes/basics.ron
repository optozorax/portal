            name: "portal",
            data: Flat(
                kind: Portal(Some(Named("portal_a")), Some(Named("portal_b"))),
                is_inside: (("if (double_sided_u == 1) {
  back = false;
}

return is_inside_portal(
  rect_distance(x, y), 
  1.0, 
  0.1,
  0.01,
  portal_blue_black_M, 
  portal_orange_black_M, 
  grid_gray_M, 
  grid_gray_M, 
  back,
  first
);

float width = 1.0;
float height = 2.0;
float border = 0.1;

if (abs(x) < width && abs(y) < height && !back) {
  if (teleport_light_u == 1) {
    if (mirror_u == 1) {
      return mirror_M;
    } else {
      return TELEPORT;
    }
  } else {
    return grid_gray_M;
  }
}

if (abs(x) < width + border && abs(y) < height + border) {
  if (first) {
    return portal_blue_black_M;
  } else {
    return portal_orange_black_M;
  }
}

return NOT_INSIDE;")),
                in_subspace: Normal,
            ),
        ),
