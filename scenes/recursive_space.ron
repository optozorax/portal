    animations: ([
        (
            name: "v3.small.0",
            data: (
                duration: 1,
                animation_stage: Animation("explore"),
                uniforms: ({
                    "enable_object": CopyPrev,
                    "enable_portals": Changed(Some(Inline(Bool(false)))),
                    "progress1": Changed(Some(Inline(Progress(0.95)))),
                    "progress2": Changed(Some(Inline(Progress(0)))),
                    "progress3": Changed(Some(Inline(Progress(0)))),
                    "progress4": Changed(Some(Inline(Progress(0)))),
                    "subspace_degree": CopyPrev,
                }),
                matrices: ({
                    "a": Changed(Some(Inline(Simple(
                        offset: (0, 0, 0),
                        scale: 1,
                        rotate: (0, 0, 0),
                        mirror: (false, false, false),
                    )))),
                    "b0": Changed(Some(Inline(Parametrized(
                        offset: (
                            x: Value(0),
                            y: Uniform(Some(Inline(Formula(("0.25*progress3"))))),
                            z: Value(0),
                        ),
