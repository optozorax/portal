(
    desc: (
        eng: "You should enter subspace using `Camera settings` -> `Inside subspace`",
        rus: "You should enter subspace using `Camera settings` -> `Inside subspace`",
    ),
    cam: (
        look_at: (0, 0, 0),
        alpha: -2.1484399952165187,
