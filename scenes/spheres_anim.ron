            name: "spheres",
            data: Complex(
                kind: Portal(Some(Named("a")), Some(Named("b"))),
                intersect: (("if (enable_spheres_u == 0) return scene_intersection_none;

int material = TELEPORT;
if (!tlight(teleport_light_u) || disable_camera_teleportation_u == 1) {
if (first) material = solid_0_M;
else material = solid_1_M;
}

if (use_box_u == 1) {
  return intersect_box(vec3(1.), r, material);
}

vec3 op = -r.o.xyz;
float b = dot(op, r.d.xyz);
float det = b*b - dot(op, op) + 1.0;
if (det < 0.) return scene_intersection_none;

det = sqrt(det);
float t = b - det;
if (t < 0.) t = b + det;
if (t < 0.) return scene_intersection_none;

vec4 pos = r.o + r.d * t;
vec3 n = normalize(pos.xyz);

float u = atan(pos.z, pos.x) / PI;
float v = atan(sqrt(pos.x * pos.x + pos.z * pos.z), pos.y) / PI;

return SceneIntersection(material, SurfaceIntersection(true, t, u, v, n), false);")),
                in_subspace: Normal,
            ),
