TwoSceneIntersections res = intersect_cube(r);

for (int i = 0; i < 2; i++) {
  SceneIntersection si = get_from_two(res, i);
  if (si.hit.hit) {
    vec4 pos = cube_mat * (r.o + r.d * si.hit.t);
    if (
      length((a_mat_inv * pos).xyz) > 1.
      && length((b_mat_inv * pos).xyz) > 1.
    ) {
      return si;
    }
  }
}

return scene_intersection_none;")),
