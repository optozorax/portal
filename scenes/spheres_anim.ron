        (
            name: "room",
            data: (("int is_inside_square(float x, float y, float sizex, float sizey, int material) {
  if (abs(x) < sizex && abs(y) < sizey) {
    return material;
  } else {
    return NOT_INSIDE;
  }
}
")),
        ),
        (
            name: "box",
            data: (("SceneIntersection intersect_box(vec3 rad, Ray r, int material) {
  vec3 m = 1.0/r.d.xyz;
  vec3 n = m*r.o.xyz;
  vec3 k = abs(m)*rad;
  vec3 t1 = -n - k;
  vec3 t2 = -n + k;

  float tN = max( max( t1.x, t1.y ), t1.z );
  float tF = min( min( t2.x, t2.y ), t2.z );

  float t = tN;
  if (tN < 0.0 && tF > 0.0) t = tF;

  if(tN > tF) return scene_intersection_none;

  if(t < 0.0) return scene_intersection_none;

  vec3 oN = -sign(r.d.xyz)*step(t1.yzx,t1.xyz)*step(t1.zxy,t1.xyz);

  vec3 pos = (r.o + r.d * t).xyz;

  vec2 uv = vec2(pos.x, pos.y);
  if (pos.z < 0.) uv.x = -uv.x;
  if (abs(abs(pos.x) - rad.x) < 0.0001) {
    uv = vec2(pos.y, pos.z);
    if (pos.x < 0.) uv.x = -uv.x;
  }
  if (abs(abs(pos.y) - rad.y) < 0.0001) {
    uv = vec2(pos.x, pos.z);
    if (pos.y > 0.) uv.x = -uv.x;
  }

  return SceneIntersection(material, SurfaceIntersection(true, t, uv.x, uv.y, normalize_normal(r.d.xyz, oN)), false);
}")),
        ),
        (
            name: "portal",
            data: (("float circle_distance(float x, float y) {
  return sqrt(sqr(x) + sqr(y));
}

float ellipse_distance(float x, float y) {
  return sqrt(2.*sqr(x) + sqr(y));
}

float square_distance(float x, float y) {
  return max(abs(x), abs(y));
}

float rect_distance(float x, float y, float a, float b) {
  return max(abs(x)-a+1., abs(y)-b+1.);
}

float triangle_distance(float x, float y, float k1, float k2, float y1) {
  return max(
    (y-k1*x)/sqrt(1.0+sqr(k1)),
  max(
    (y-k2*x)/sqrt(1.0+sqr(k2)),
    -y1 * y
  ));
}

int is_inside_object(
  float distance, 
  float size, 
  float border,
  int material_inner, 
  int material_border
) {
  if (distance < size) return material_inner;
  if (distance < size + border) return material_border;
  return NOT_INSIDE;
}

int is_inside_portal(
  float distance, 
  float size, 
  float border,
  float black_border,
  int material_first, 
  int material_second, 
  int grid_material_first, 
  int grid_material_second, 
  bool back,
  bool first
) {
  int material = material_second;
  if (first) { material = material_first; }

  if (distance < size) {
    if (back) {
      return material;      
    } else {
      if (tlight(teleport_light_u)) {
      	if (mirror_u == 1) {
          return mirror_M;
        } else {
          return TELEPORT;
        }
      } else {
        if (first) {
          return grid_material_first;
        } else {
          return grid_material_second;
        }
      }
    }
  }
  int black_material = solid_black_M;
  if (_black_border_disable == 1) black_material = material;
  if (distance < size + black_border && !back) return black_material;
  if (distance < size + black_border + border) return material;
  if (distance < size + black_border + border + black_border) return black_material;

  return NOT_INSIDE;
}")),
        ),
        (
            name: "companion_cube",
            data: (("vec3 companion_cube_color(float u, float v) {
  float mul = 1.;
  float dist = sqrt(u * u + v * v);
  float circle_size = 0.6;
  float circle_border = 0.03;
  if (dist < circle_size + circle_border && dist > circle_size) { mul = 0.4; }
  if (dist > circle_size + circle_border) { mul = (PI + atan(u, v))/(2.0*PI); }

  if (dist < circle_size) {
    float scale = 3.;
    float x = u * scale;
    float y = v * scale + 0.26;
    float temp1 = x*x + y*y - 1.;
    if (temp1 * temp1 * temp1 - x * x * y * y * y < 0.) {
      return vec3(222., 35., 138.) / 255.;
    }
  }

  return color_grid3(vec3(9.176470588235294e-1, 9.176470588235294e-1, 9.176470588235294e-1) * mul, vec2(u + 1., v + 1.));
}")),
        ),
        (
            name: "two_intersections",
            data: (("SceneIntersection process_t_cube(Ray r, float t, vec3 oN, vec3 rad) {
  if (t < 0.) return scene_intersection_none;
  vec3 sizes = vec3(room_size_x_u, room_size_y_u, room_size_z_u);

  vec3 pos = (r.o + r.d * t).xyz;

  vec2 uv = vec2(pos.x, pos.y);
  if (pos.z < 0.) uv.x = -uv.x;
  if (abs(abs(pos.x) - rad.x) < 0.0001) {
    uv = vec2(pos.y, pos.z);
    if (pos.x < 0.) uv.x = -uv.x;
  }
  if (abs(abs(pos.y) - rad.y) < 0.0001) {
    uv = vec2(pos.x, pos.z);
    if (pos.y > 0.) uv.x = -uv.x;
  }

  int material = companion_cube_M;

  return SceneIntersection(material, SurfaceIntersection(true, t, uv.x, uv.y, normalize_normal(r.d.xyz, oN)), false);
}


struct TwoSceneIntersections {
  SceneIntersection first;
  SceneIntersection second;  
};

TwoSceneIntersections intersect_cube(Ray r) {
  vec3 sizes = vec3(1.);

  vec3 m = 1.0 / r.d.xyz;
  vec3 n = m * r.o.xyz;
  vec3 k = abs(m) * sizes;
  vec3 vt1 = -n - k;
  vec3 vt2 = -n + k;

  float t1 = max(max(vt1.x, vt1.y), vt1.z);
  float t2 = min(min(vt2.x, vt2.y), vt2.z);

  vec3 n1 = -sign(r.d.xyz) * step(vt1.yzx,vt1.xyz) * step(vt1.zxy,vt1.xyz);
  vec3 n2 = -sign(r.d.xyz) * step(vt2.xyz, vt2.yzx) * step(vt2.xyz, vt2.zxy);

  if (t1 > t2) return TwoSceneIntersections(
    scene_intersection_none,
    scene_intersection_none
  );

  return TwoSceneIntersections(
    process_t_cube(r, t1, n1, sizes),
    process_t_cube(r, t2, n2, sizes)
  );
}

SceneIntersection get_from_two(TwoSceneIntersections res, int pos) {
  if (pos == 0) return res.first;
  return res.second;
}")),
