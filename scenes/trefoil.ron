            name: "Trefoil knot",
            data: Complex(
                kind: Portal(Some(Named("empty")), Some(Named("empty"))),
                intersect: (("SceneIntersection sc = scene_intersection_none;
bool f = first;

int size = 18;
for (int i = 0; i < 18; i++) { if (i >= size) break; // !FOR_NUMBER!
for (int i = 0; i < size; i++) { // !FOR_VARIABLE!
	int current_var = ts_0_trefoil_u;
	if (i == 0) { current_var = ts_0_trefoil_u; }
	else if (i == 1) { current_var = ts_1_trefoil_u; }
	else if (i == 2) { current_var = ts_2_trefoil_u; }
	else if (i == 3) { current_var = ts_3_trefoil_u; }
	else if (i == 4) { current_var = ts_4_trefoil_u; }
	else if (i == 5) { current_var = ts_5_trefoil_u; }
	else if (i == 6) { current_var = ts_6_trefoil_u; }
	else if (i == 7) { current_var = ts_7_trefoil_u; }
	else if (i == 8) { current_var = ts_8_trefoil_u; }
	else if (i == 9) { current_var = ts_9_trefoil_u; }
	else if (i == 10) { current_var = ts_10_trefoil_u; }
	else if (i == 11) { current_var = ts_11_trefoil_u; }
	else if (i == 12) { current_var = ts_12_trefoil_u; }
	else if (i == 13) { current_var = ts_13_trefoil_u; }
	else if (i == 14) { current_var = ts_14_trefoil_u; }
	else if (i == 15) { current_var = ts_15_trefoil_u; }
	else if (i == 16) { current_var = ts_16_trefoil_u; }
	else if (i == 17) { current_var = ts_17_trefoil_u; }

	if (current_var >= 10000) sc=pp2(sc,r,f,i,current_var-10000);
}

return sc;")),
                in_subspace: Normal,
            ),
        ),
