        (
            name: "box",
            data: (("SceneIntersection intersect_box(Ray r, int material, vec3 rad) {
vec3 m = 1.0/r.d.xyz;
vec3 n = m*r.o.xyz;
vec3 k = abs(m)*rad;
vec3 t1 = -n - k;
vec3 t2 = -n + k;

float tN = max( max( t1.x, t1.y ), t1.z );
float tF = min( min( t2.x, t2.y ), t2.z );

float t = tN;
if (tN < 0.0 && tF > 0.0) t = tF;

if(tN > tF) return scene_intersection_none;

if(t < 0.0) return scene_intersection_none;

vec3 oN = -sign(r.d.xyz)*step(t1.yzx,t1.xyz)*step(t1.zxy,t1.xyz);

vec3 pos = (r.o + r.d * t).xyz;

vec2 uv = vec2(pos.x, pos.y);
if (abs(abs(pos.x) - rad.x) < 0.0001) {
  uv = vec2(pos.y, pos.z);
}
if (abs(abs(pos.y) - rad.y) < 0.0001) {
  uv = vec2(pos.x, pos.z);
}

return SceneIntersection(material, SurfaceIntersection(true, t, uv.x, uv.y, normalize_normal(r.d.xyz, oN)), false);
}")),
        ),
        (
            name: "portal",
            data: (("float circle_distance(float x, float y) {
  return sqrt(sqr(x) + sqr(y));
}

float ellipse_distance(float x, float y) {
  return sqrt(2.*sqr(x) + sqr(y));
}

float square_distance(float x, float y) {
  return max(abs(x), abs(y));
}

float rect_distance(float x, float y, float a, float b) {
  return max(abs(x)-a+1., abs(y)-b+1.);
}

float triangle_distance(float x, float y, float k1, float k2, float y1) {
  return max(
    (y-k1*x)/sqrt(1.0+sqr(k1)),
  max(
    (y-k2*x)/sqrt(1.0+sqr(k2)),
    -y1 * y
  ));
}

int is_inside_object(
  float distance, 
  float size, 
  float border,
  int material_inner, 
  int material_border
) {
  if (distance < size) return material_inner;
  if (distance < size + border) return material_border;
  return NOT_INSIDE;
}

int is_inside_portal(
  float distance, 
  float size, 
  float border,
  float black_border,
  int material_first, 
  int material_second, 
  int grid_material_first, 
  int grid_material_second, 
  bool back,
  bool first
) {
  int material = material_second;
  if (first) { material = material_first; }

  if (distance < size) {
    if (back) {
      return material;      
    } else {
      if (tlight(teleport_light_u)) {
      	if (mirror_u == 1) {
          return mirror_M;
        } else {
          return TELEPORT;
        }
      } else {
        if (first) {
          return grid_material_first;
        } else {
          return grid_material_second;
        }
      }
    }
  }
  int black_material = solid_black_M;
  if (_black_border_disable == 1) black_material = material;
  if (distance < size + black_border && !back) return black_material;
  if (distance < size + black_border + border) return material;
  if (distance < size + black_border + border + black_border) return black_material;

  return NOT_INSIDE;
}")),
        ),
        (
            name: "part",
            data: (("int is_inside_part(vec4 pos, float x, float y, bool back) {
  return is_inside_square(x, y, 0.3, 0.3, room_yellow_M);
}

SurfaceIntersection cap_body(Ray r, vec3 pa, vec3 pb, float radius) {
    vec3 ro = r.o.xyz;
    vec3 rd = r.d.xyz;
    vec3 ba = pb - pa;
    vec3 oa = ro - pa;

    float baba = dot(ba,ba);
    float bard = dot(ba,rd);
    float baoa = dot(ba,oa);
    float rdoa = dot(rd,oa);
    float oaoa = dot(oa,oa);

    float a = baba      - bard*bard;
    float b = baba*rdoa - baoa*bard;
    float c = baba*oaoa - baoa*baoa - radius*radius*baba;
    float h = b*b - a*c;
    if( h>=0.0 ) {
        float t = (-b-sqrt(h))/a;
        float y = baoa + t*bard;
        // body
        if( y>0.0 && y<baba ) {
            vec3 pos = ro + rd * t;
            return SurfaceIntersection(true, t, 0., 0., cap_normal(pos, pa, pb, radius));
        }
    }
    return intersection_none;
}

bool is_inside_box(Ray r, vec3 size) {
  vec3 m = 1.0/r.d.xyz;
  vec3 n = m*r.o.xyz;
  vec3 k = abs(m)*size;
  vec3 t1 = -n - k;
  vec3 t2 = -n + k;

  float tN = max( max( t1.x, t1.y ), t1.z );
  float tF = min( min( t2.x, t2.y ), t2.z );

  float t = tN;
  if (tN < 0.0 && tF > 0.0) {
    t = tF;
  } 

  return !(tN > tF || t < 0.0);
}

SceneIntersection intersect_part(Ray r, bool first, bool is_portal, bool back, int color) {
  float b = border_size_u + black_border_size_u+0.02;
  vec3 offset_box = vec3(b_u, a_u*2.-b_u, a_u);
  vec3 size_box = vec3(b_u+b, b_u+b, a_u+b);
  r.o.xyz -= offset_box;
  if (!is_inside_box(r, size_box)) return scene_intersection_none;
  r.o.xyz += offset_box;  


  SceneIntersection i = SceneIntersection(0, intersection_none, false);
  SurfaceIntersection hit = intersection_none;
  SurfaceIntersection hit2 = intersection_none;
  SurfaceIntersection hita = intersection_none;
  SurfaceIntersection hitb = intersection_none;
  vec3 normal = vec3(0.);
  float sz = 0.1;
  float szb = 0.01;
  vec4 ro = r.o;
  float radius = border_size_u;

  int border_material = color;

if (enable_border_u == 1 && !back) {
  vec3 c1 = vec3(0., a_u*2., 0.);
  vec3 c2 = vec3(b_u*2., a_u*2., 0.);
  vec3 c3 = vec3(b_u*2., (-b_u+a_u)*2., 0.);
  vec3 c4 = vec3(b_u*2.,(-b_u+a_u)*2., a_u*2.);
  vec3 c5 = vec3(0., (-b_u+a_u)*2., a_u*2.);
  vec3 c6 = vec3(0., 0., a_u*2.);
  float br = black_border_size_u;

  hit = cap_body(r, c1, c2, radius);
  if (nearer(i, hit)) {
      i.material = border_material;
      i.hit = hit;
  }
if (enable_black_border_u == 1) {
  hita = hit;
  hit = cap_body(r, c1-(c2-c1)*10., c2, radius);
  hit2 = cap_body(r, c1, c2-vec3(radius+br, 0., 0.), radius+br);
  if (!hita.hit && !hit.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }
}

  hit = cap(r, c2, c3, radius);
  if (nearer(i, hit)) {
      i.material = border_material;
      i.hit = hit;
  }
if (enable_black_border_u == 1) {
  hitb = hit;
  hit2 = cap_body(r, c2-vec3(0., radius+br, 0.), c3+vec3(0., radius+br, 0.), radius+br);
  if (!hit.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }
  
  hit2 = cap(r, c2-vec3(0., radius+br, 0.), c2, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }

  hit2 = cap(r, c2-vec3(radius+br, 0., 0.), c2, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }

  hita = hitb;
}
  hit = cap(r, c3, c4, radius);
  if (nearer(i, hit)) {
      i.material = border_material;
      i.hit = hit;
  }
if (enable_black_border_u == 1) {
  hitb = hit;
  hit2 = cap_body(r, c3+vec3(0., 0., radius+br), c4-vec3(0., 0., radius+br), radius+br);
  if (!hit.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }

  hit2 = cap(r, c3+vec3(0., radius+br, 0.), c3, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }
  hit2 = cap(r, c3+vec3(0., 0., radius+br), c3, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }

  hita = hitb;
}
  hit = cap(r, c4, c5, radius);
  if (nearer(i, hit)) {
      i.material = border_material;
      i.hit = hit;
  }
if (enable_black_border_u == 1) {
  hitb = hit;
  hit2 = cap_body(r, c4-vec3(radius+br, 0., 0.), c5+vec3(radius+br, 0., 0.), radius+br);
  if (!hit.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }

  hit2 = cap(r, c4-vec3(radius+br, 0., 0.), c4, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }
  hit2 = cap(r, c4-vec3(0., 0., radius+br), c4, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }


  hita = hitb;
}
  hit = cap_body(r, c5, c6, radius);
  if (nearer(i, hit)) {
      i.material = border_material;
      i.hit = hit;
  }
if (enable_black_border_u == 1) {
  hitb = hit;
  hit = cap_body(r, c6-(c5-c6)*10., c5, radius);
  hit2 = cap_body(r, c5+vec3(0., radius+br, 0.), c6, radius+br);
  if (!hit.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }
  hit2 = cap(r, c5+vec3(radius+br, 0., 0.), c5, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }
  hit2 = cap(r, c5+vec3(0., radius+br, 0.), c5, radius+br);
  if (!hita.hit && !hitb.hit && nearer(i, hit2)) {
    i.hit = hit2;
    i.material = solid_black_M;
  }
}
}

  if (!is_portal) return i;
  
  r.o = ro - vec4(0., -b_u+a_u, a_u, 0.);
  normal = -get_normal(a1_mat);
  hit = plane_intersect(r, a1_mat_inv, get_normal(a1_mat));
  if (nearer(i, hit)) { 
    int inside = NOT_INSIDE;
    float distance = rect_distance(hit.u, hit.v, b_u-a_u, a_u);
    if (distance <= 1.0 && is_collinear(hit.n, normal) == back) {
      i.hit = hit;
      i.material = TELEPORT;
    }
  }

  r.o = ro - vec4(b_u, -b_u+a_u*2., 0., 0.);
  normal = -get_normal(b1_mat);
  hit = plane_intersect(r, b1_mat_inv, get_normal(b1_mat));
  if (nearer(i, hit)) { 
    float distance = rect_distance(hit.u, hit.v, b_u, b_u);
    if (distance <= 1.0 && is_collinear(hit.n, normal) == back) {
      i.hit = hit;
      i.material = TELEPORT;
    }
  }

  r.o = ro - vec4(b_u, -2.*b_u+a_u*2., a_u, 0.);
  normal = -get_normal(c1_mat);
  hit = plane_intersect(r, c1_mat_inv, get_normal(c1_mat));
  if (nearer(i, hit)) { 
    int inside = NOT_INSIDE;
    float distance = rect_distance(hit.u, hit.v, b_u, a_u);
    if (distance <= 1.0 && is_collinear(hit.n, normal) == back) {
      i.hit = hit;
      i.material = TELEPORT;
    }
  }

  return i;
}")),
        ),
        (
            name: "part2",
            data: (("SceneIntersection intersect_parts_helper(
    Ray r,
    bool first,
    mat4 m_mat,
    mat4 m_inv,
    float first_no,
    float second_no,
    int color
) {
    Ray transformed_ray = transform(m_inv, r);
    float len = length(transformed_ray.d);
    transformed_ray.d = normalize(transformed_ray.d);
    SceneIntersection ihit = intersect_part(transformed_ray, first, true, first, color);
    ihit.hit.t /= len;
    if (ihit.hit.hit && ihit.material != NOT_INSIDE) { 
        if (ihit.material == TELEPORT) { 
            if (!tlight(teleport_light_u)) { ihit.material = grid_gray_M; } else {
              ihit.material = custom_teleport_M;
              ihit.hit.u = first_no;
              ihit.hit.v = second_no;
            }
        }
        ihit.hit.n = normalize((m_mat * vec4(ihit.hit.n, 0.)).xyz);
        return ihit;
    }
    return scene_intersection_none;
}

SceneIntersection intersect_parts(
    Ray r,
    bool first,
    mat4 first_mat,
    mat4 first_inv,
    float first_no,
    mat4 second_mat,
    mat4 second_inv,
    float second_no,
    int color
) {
    if (!first) {
        return intersect_parts_helper(r, first, first_mat, first_inv, first_no, second_no, color);
    } else {
        return intersect_parts_helper(r, first, second_mat, second_inv, second_no, first_no, color);
    }
}

mat4 get_mat(int number) {
         if (number == 0) { return portal1_p1_mat; }
    else if (number == 1) { return portal1_p2_mat; }
    else if (number == 2) { return portal1_p3_mat; }

    else if (number == 3) { return portal2_p1_mat; }
    else if (number == 4) { return portal2_p2_mat; }
    else if (number == 5) { return portal2_p3_mat; }

    else if (number == 6) { return portal3_p1_mat; }
    else if (number == 7) { return portal3_p2_mat; }
    else if (number == 8) { return portal3_p3_mat; }

    else if (number == 9) { return portal4_p1_mat; }
    else if (number ==10) { return portal4_p2_mat; }
    else if (number ==11) { return portal4_p3_mat; }

    else if (number ==12) { return portal5_p1_mat; }
    else if (number ==13) { return portal5_p2_mat; }
    else if (number ==14) { return portal5_p3_mat; }

    else if (number ==15) { return portal6_p1_mat; }
    else if (number ==16) { return portal6_p2_mat; }
    else if (number ==17) { return portal6_p3_mat; }

    else { return portal1_p1_mat; }
}

mat4 get_mat_inv(int number) {
         if (number == 0) { return portal1_p1_mat_inv; }
    else if (number == 1) { return portal1_p2_mat_inv; }
    else if (number == 2) { return portal1_p3_mat_inv; }

    else if (number == 3) { return portal2_p1_mat_inv; }
    else if (number == 4) { return portal2_p2_mat_inv; }
    else if (number == 5) { return portal2_p3_mat_inv; }

    else if (number == 6) { return portal3_p1_mat_inv; }
    else if (number == 7) { return portal3_p2_mat_inv; }
    else if (number == 8) { return portal3_p3_mat_inv; }

    else if (number == 9) { return portal4_p1_mat_inv; }
    else if (number ==10) { return portal4_p2_mat_inv; }
    else if (number ==11) { return portal4_p3_mat_inv; }

    else if (number ==12) { return portal5_p1_mat_inv; }
    else if (number ==13) { return portal5_p2_mat_inv; }
    else if (number ==14) { return portal5_p3_mat_inv; }

    else if (number ==15) { return portal6_p1_mat_inv; }
    else if (number ==16) { return portal6_p2_mat_inv; }
    else if (number ==17) { return portal6_p3_mat_inv; }

    else { return portal1_p1_mat; }
}

SceneIntersection pp2(
    SceneIntersection sc,
    Ray r,
    bool first,
    int a,
    int b
) {
    int color = 0;
    int size = 20;
    for (int i = 0; i < 20; i++) { if (i >= size) break; // !FOR_NUMBER!
    for (int i = 0; i < size; i++) { // !FOR_VARIABLE!
        if (b >= 1000) {
           b -= 1000;
           color += 1;
        } else {
            break;
        }
    }
    int color2 = room_red_M;
    if (color == 0) color2 = portal_orange_M;
    if (color == 1) color2 = portal_green_M;
    if (color == 2) color2 = portal_blue_M;
    if (color == 3) color2 = room_yellow_M;
    if (color == 4) color2 = room_violet_M;
    if (color == 5) color2 = room_gray_M;
    SceneIntersection ihit = intersect_parts(
      r,
      first,
      get_mat(a),
      get_mat_inv(a),
      float(a) + 0.1,
      get_mat(b),
      get_mat_inv(b),
      float(b) + 0.1,
      color2
    );
    if (nearer(sc, ihit)) { sc = ihit; }
    return sc;
}

SceneIntersection pp(
    SceneIntersection sc,
    Ray r,
    bool first,
    int ar, int ap,
    int br, int bp
) {
    int a = ar * 3 + ap;
    int b = br * 3 + bp;
    return pp2(sc, r, first, a, b);
}")),
