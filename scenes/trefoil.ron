  if (condition) {
    return !value;
  } else {
    return value;
  }
}

float  ease_in_out(float x) {
if (x < 0.5) {
  return 4. * x * x * x;
} else {
  float temp = -2. * x + 2.;
  return 1. - temp * temp * temp / 2.;
}
}")),
        ),
        (
            name: "room",
            data: (("int is_inside_square(float x, float y, float sizex, float sizey, int material) {
  if (abs(x) < sizex && abs(y) < sizey) {
    return material;
  } else {
    return NOT_INSIDE;
  }
}
")),
