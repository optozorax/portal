        (
            name: "object",
            data: Complex(
                kind: Simple(Some(Named("object"))),
                intersect: (("vec3 op = -r.o.xyz;
float b = dot(op, r.d.xyz);
float det = b*b - dot(op, op) + 1.0;
if (det < 0.) return scene_intersection_none;

det = sqrt(det);
float t = b - det;
if (t < 0.) t = b + det;
if (t < 0.) return scene_intersection_none;

vec4 pos = r.o + r.d * t;

vec4 pos1 = (a_mat_inv * (object_mat * pos));
if (pos1.x > 0.) {
  if ((right_mat_inv * pos1).z < 0.) {
    return scene_intersection_none;
  }
} else {
  if ((left_mat_inv * pos1).z < 0.) {
    return scene_intersection_none;
  }
}

vec3 n = normalize(pos.xyz);

float u = atan(pos.z, pos.x);
float v = atan(sqrt(pos.x * pos.x + pos.z * pos.z), pos.y);

return SceneIntersection(grid_gray_2_M, SurfaceIntersection(true, t, u, v, n), false);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "object_teleported",
            data: Complex(
                kind: Simple(Some(Inline(Teleport(
                    first_portal: Some(Named("a")),
                    second_portal: Some(Named("b")),
                    what: Some(Named("object")),
                )))),
                intersect: (("vec3 op = -r.o.xyz;
float b = dot(op, r.d.xyz);
float det = b*b - dot(op, op) + 1.0;
if (det < 0.) return scene_intersection_none;

det = sqrt(det);
float t = b - det;
if (t < 0.) t = b + det;
if (t < 0.) return scene_intersection_none;

vec4 pos = r.o + r.d * t;

vec4 pos1 = (a_mat_inv * (object_mat * pos));
if (pos1.x > 0.) {
  if ((right_mat_inv * pos1).z > 0.) {
    return scene_intersection_none;
  }
} else {
  if ((left_mat_inv * pos1).z > 0.) {
    return scene_intersection_none;
  }
}

vec3 n = normalize(pos.xyz);

float u = atan(pos.z, pos.x);
float v = atan(sqrt(pos.x * pos.x + pos.z * pos.z), pos.y);

return SceneIntersection(grid_gray_2_M, SurfaceIntersection(true, t, u, v, n), false);")),
                in_subspace: Normal,
            ),
        ),
