                )))),
                is_inside: (("if (x > len_u) return NOT_INSIDE;

return is_inside_portal(
  rect_distance(x, y, len_u, 0.5),
  1.0,
  0.05,
  0.01,
  portal_blue_black_M,
  portal_orange_black_M,
  grid_gray_M,
  grid_gray_M,
  back,
  first
);")),
