                second_portal: Some(Named("b")),
                what: Some(Named("tr2")),
            ),
            "tr_teleported": Teleport(
                first_portal: Some(Named("a")),
                second_portal: Some(Named("b")),
                what: Some(Named("tr")),
            ),
