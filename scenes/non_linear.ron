            name: "red_line",
            data: Complex(
                kind: Simple(Some(Inline(Mul(
                    to: Some(Named("trajectory")),
                    what: Some(Named("b")),
                )))),
                intersect: (("if (enable_trajectory_u == 0) return scene_intersection_none;

if (enable_red_u == 0) return scene_intersection_none;

float t1 = 0.58;
float t2 = 7.;
vec3 a = vec3(-sin(alpha_u)*t1+x_offset_u, 0., -cos(alpha_u)*t1);
vec3 b = vec3(-sin(alpha_u)*t2+x_offset_u, 0., -cos(alpha_u)*t2);

SurfaceIntersection result = cap(r, a, b, trajectory_width_u);

if (trajectory_over_everything_u == 1 && result.t > 0.) result.t = 0.01;

return SceneIntersection(red_trajectory_M, result, false);
")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "tor",
            data: Complex(
                kind: Simple(Some(Inline(Mul(
                    to: Some(Inline(Simple(
                        offset: (-2.5, 0.0, 0.0),
                        scale: 1.0,
                        rotate: (1.5707963267948966, 0.0, 0.0),
                        mirror: (false, false, false),
                    ))),
                    what: Some(Inline(Mul(
                        to: Some(Named("trajectory")),
                        what: Some(Named("b")),
                    ))),
                )))),
                intersect: (("if (enable_trajectory_u == 0) return scene_intersection_none;

vec2 tor = vec2(2.5, trajectory_width_u);

float t = torIntersect(r.o.xyz, r.d.xyz, tor);

if (t < 0.01 || t > 20.) return scene_intersection_none;

vec3 pos = (r.o + r.d * t).xyz;

int material = gray_trajectory_M;

if (pos.y > -0.59) {
  if (pos.x < 0.) return scene_intersection_none;
} else {
   material = blue_trajectory_M;
   if (enable_blue_u == 0) return scene_intersection_none;
}

if (trajectory_over_everything_u == 1) t = 0.01;

return SceneIntersection(material, SurfaceIntersection(true, t, 0., 0., torNormal(pos, tor)), false);")),
                in_subspace: Normal,
            ),
        ),
