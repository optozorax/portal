            "variant": Bool(true),
            "x_offset": Formula(("2.5-2.5*cos(alpha)")),
        },
        matrices: {
            "a": Mul(
                to: Some(Inline(Simple(
                    offset: (2.5, 0.0, 0.0),
                    scale: 1.0,
                    rotate: (0.0, 0.0, 0.0),
                    mirror: (false, false, false),
                ))),
                what: Some(Inline(Parametrized(
                    offset: (
                        x: Value(0.0),
                        y: Value(0.0),
                        z: Value(-2.5),
                    ),
                    rotate: (
                        x: Value(0.0),
                        y: Uniform(Some(Named("angle"))),
                        z: Value(0.0),
                    ),
                    mirror: (
                        x: Value(0.0),
                        y: Value(0.0),
                        z: Value(0.0),
                    ),
                    scale: Value(1.0),
                ))),
            ),
            "b": Simple(
                offset: (-2.5, -2.5, -2.5),
                scale: 1.0,
                rotate: (0.0, 3.141592653589793, 0.0),
                mirror: (false, false, false),
            ),
            "cylinder1": Simple(
                offset: (-2.5, 0.0, 0.0),
                scale: 1.0,
                rotate: (1.5707963267948966, 0.0, 0.0),
                mirror: (true, false, false),
            ),
            "cylinder2": Simple(
                offset: (-5.0, 0.0, 0.0),
                scale: 1.0,
                rotate: (0.0, 0.0, 0.0),
                mirror: (false, false, false),
            ),
            "cylinder3": Simple(
                offset: (-2.5, 1.0, 0.0),
                scale: 1.0,
                rotate: (1.5707963267948966, 0.0, 1.5707963267948966),
                mirror: (false, false, false),
            ),
            "cylinder4": Simple(
                offset: (-2.5, -1.0, 0.0),
                scale: 1.0,
                rotate: (1.5707963267948966, 0.0, 1.5707963267948966),
                mirror: (false, false, false),
            ),
            "room_origin": Simple(
                offset: (0.0, 0.0, 0.0),
                scale: 1.0,
                rotate: (0.0, 0.0, 0.0),
                mirror: (false, false, false),
            ),
            "tr": If(
                condition: Uniform(Some(Inline(Formula(("and(inv(is_touch), 1)"))))),
                then: Some(Inline(Mul(
                    to: Some(Inline(Parametrized(
                        offset: (
                            x: Uniform(Some(Inline(Formula(("-speed*sin(alpha)*object_time+x_offset"))))),
                            y: Value(0.0),
                            z: Uniform(Some(Inline(Formula(("-speed*cos(alpha)*object_time"))))),
                        ),
                        rotate: (
                            x: Value(1.5707963267948966),
                            y: Value(0.0),
                            z: Uniform(Some(Inline(Formula(("angle"))))),
                        ),
                        mirror: (
                            x: Value(0.0),
                            y: Value(0.0),
                            z: Value(0.0),
                        ),
                        scale: Value(0.5),
                    ))),
                    what: Some(Named("a")),
                ))),
                otherwise: Some(Inline(Simple(
                    offset: (2.5, 0.0, -2.5),
                    scale: 0.5,
                    rotate: (1.5707963267948966, 0.0, 0.0),
                    mirror: (false, false, false),
                ))),
            ),
            "tr2": Simple(
                offset: (2.5, 0.0, -2.5),
                scale: 0.5,
                rotate: (1.5707963267948966, 0.0, 0.0),
                mirror: (false, false, false),
            ),
            "tr2_teleported": Teleport(
