    current_stage: Animation("Explore"),
    dev_stage: (
        uniforms: {
            "alpha": Formula(("11.53/180*pi()")),
            "angle": Formula(("-my_time*pi()+alpha*2")),
            "cylinder_enable": Bool(false),
            "cylinder_height": Float((
                min: None,
                max: None,
                value: 1.0,
            )),
            "cylinder_progress": Progress(0.5),
            "cylinder_radius": Float((
