                min: Some(0.0),
                max: None,
                value: 8.0,
            )),
            "speed": Formula(("2.5")),
            "teleport_light": Bool(true),
            "time_speed": Float((
                min: Some(0.1),
                max: Some(1.0),
                value: 0.2,
            )),
            "trajectory_over_everything": Bool(false),
            "trajectory_width": Float((
