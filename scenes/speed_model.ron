            ),
        ),
        (
            name: "triangle",
            data: Flat(
                kind: Simple(Some(Named("triangle"))),
                is_inside: (("if (enable_half_spheres_u == 0 && (portal_a_mat_inv * pos).z < 0.) return NOT_INSIDE;

return is_inside_triangle(x, y, 2.0, 2.0, 0.04, triangle_white_M, triangle_black_M);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "triangle_teleported",
            data: Flat(
                kind: Simple(Some(Named("tt2"))),
                is_inside: (("if ((portal_b_mat_inv * pos).z > 0. || enable_half_spheres_u == 1) return NOT_INSIDE;

return is_inside_triangle(x, y, 2.0, 2.0, 0.04, triangle_white_M, triangle_black_M);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "half-sphere",
            data: Complex(
                kind: Portal(Some(Inline(Mul(
                    to: Some(Named("half_sphere_xyz")),
                    what: Some(Named("portal_a")),
                ))), Some(Inline(Mul(
                    to: Some(Named("half_sphere_xyz")),
                    what: Some(Named("portal_b")),
                )))),
                intersect: (("if (enable_half_spheres_u == 0) return scene_intersection_none;

vec3 op = -r.o.xyz;
float b = dot(op, r.d.xyz);
float det = b*b - dot(op, op) + 1.0;
if (det < 0.) return scene_intersection_none;

det = sqrt(det);
float t = b - det;
vec4 pos = r.o + r.d * t;
if (pos.z > 0. || t < 0.) t = b + det;
pos = r.o + r.d * t;
if (pos.z > 0. || t < 0.) return scene_intersection_none;

vec3 n = normalize(pos.xyz);

float u = atan(pos.z, pos.x);
float v = atan(sqrt(pos.x * pos.x + pos.z * pos.z), pos.y);

int material = TELEPORT;
if (teleport_light_u == 0) material = grid_gray_M;

if (two_sided_u == 0 && ((first && dot(n, r.d.xyz) < 0.) || (!first && dot(n, r.d.xyz) > 0.))) {
if (first) { material = portal_blue_grid_M;
} else { material = portal_orange_grid_M; }
}

return SceneIntersection(material, SurfaceIntersection(true, t, u, v, n), false);")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "half-sphere border",
            data: Flat(
                kind: Portal(Some(Named("portal_a")), Some(Named("portal_b"))),
                is_inside: (("if (enable_half_spheres_u == 0) return NOT_INSIDE;

float distance = circle_distance(x, y);
if (distance < 1.) distance = 2.;
int result = is_inside_portal(
  distance,
  1.0,
  0.05,
  0.01,
  portal_blue_M,
  portal_orange_M,
  grid_gray_M,
  grid_gray_M,
  false,
  first
);
if (result == TELEPORT) return NOT_INSIDE;

return result;")),
                in_subspace: Normal,
            ),
        ),
