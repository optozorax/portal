        (
            name: "portal",
            data: Flat(
                kind: Portal(Some(Named("portal_a")), Some(Named("portal_b"))),
                is_inside: (("if (enable_half_spheres_u == 1) return NOT_INSIDE;

return is_inside_portal(
  square_distance(x, y), 
  1.0, 
  0.1,
  0.01,
  portal_orange_M, 
  portal_blue_M, 
  grid_gray_M, 
  grid_gray_M, 
  back,
  first
);")),
