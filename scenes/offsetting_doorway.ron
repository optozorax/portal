            data: Flat(
                kind: Portal(Some(Named("portal_a")), Some(Named("portal_b"))),
                is_inside: (("float width = 1.0;
float height = 1.0;
float border = 0.1;

if (abs(x) < width && abs(y) < height && !back) {
  if (teleport_light_u == 1) {
    if (mirror_u == 1) {
      return mirror_M;
    } else {
      return TELEPORT;
    }
  } else {
    return grid_gray_M;
  }
}

if (abs(x) < width + border && abs(y) < height) {
  if (first) {
    return solid_black_M;
  } else {
    return solid_black_M;
  }
}

return NOT_INSIDE;")),
