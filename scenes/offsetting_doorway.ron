if (abs(x) < 1. + border && between(0.-border, -y, 4.)) return solid_black_M;

if (back) {
  return is_inside_square(x, y, 4.0, 4.0, room_red_M);
} else {
  return is_inside_square(x, y, 4.0, 4.0, room_blue_M);
