        (
            name: "object",
            data: Complex(
                kind: Simple(Some(Named("object"))),
                intersect: (("if (enable_object_u == 0) return scene_intersection_none;

SceneIntersection result = object_intersect(r);
if (!result.hit.hit) return scene_intersection_none;

vec4 pos_absolute = object_mat * (r.o + r.d * result.hit.t);

vec4 ray_o = object_vector_mat * vec4(0., 0., 0., 1.);
vec4 ray_d = normalize(pos_absolute - ray_o);
Ray r2 = Ray(ray_o, ray_d, 1.0, false);

Ray r_mob = transform(mobius_a_final_mat_inv, r2);
float len_mob = length(r_mob.d.xyz);
r_mob.d = normalize(r_mob.d);
SurfaceIntersection hit_mob = mobius_intersect(r_mob);
hit_mob.t /= len_mob;

float obj_t = length(pos_absolute - ray_o);

if (hit_mob.t < obj_t) return scene_intersection_none;

return result;")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "object_teleported",
            data: Complex(
                kind: Simple(Some(Named("object_teleported"))),
                intersect: (("if (enable_object_u == 0) return scene_intersection_none;

SceneIntersection result = object_intersect(r);
if (!result.hit.hit) return scene_intersection_none;

vec4 pos = r.o + r.d * result.hit.t;
vec4 pos_absolute = object_teleported_mat * pos;

vec4 ray_o = object_vector_teleported_mat * vec4(0., 0., 0., 1.);
vec4 ray_d = normalize(pos_absolute-ray_o);
Ray r2 = Ray(ray_o, ray_d, 1.0, false);

Ray r_mob = transform(mobius_b_final_mat_inv, r2);
float len_mob = length(r_mob.d);
r_mob.d = normalize(r_mob.d);
SurfaceIntersection hit_mob = mobius_intersect(r_mob);
hit_mob.t /= len_mob;

float obj_t = length(pos_absolute - ray_o);

if (hit_mob.t > obj_t) return scene_intersection_none;

return result;")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "object_vector",
            data: Complex(
                kind: Simple(Some(Named("object_vector"))),
                intersect: (("if (enable_object_u == 0) return scene_intersection_none;

float radius = 0.03;

SurfaceIntersection hit = intersection_none;
SceneIntersection i = SceneIntersection(0, hit, false);

hit = cap(r, vec3(0., 0., 0.), vec3(1., 0., 0.), radius);
if (nearer(i, hit)) {
  i.material = DEBUG_RED;
  i.hit = hit;
}

hit = cap(r, vec3(1., 0., 0.), vec3(0.9, 0., -0.1), radius);
if (nearer(i, hit)) {
  i.material = DEBUG_RED;
  i.hit = hit;
}

hit = cap(r, vec3(1., 0., 0.), vec3(0.9, 0.0, 0.1), radius);
if (nearer(i, hit)) {
  i.material = DEBUG_RED;
  i.hit = hit;
}

hit = cap(r, vec3(0., -0.2, 0.), vec3(0., 0.2, 0.), radius);
if (nearer(i, hit)) {
  i.material = DEBUG_GREEN;
  i.hit = hit;
}

hit = cap(r, vec3(0., 0., -0.2), vec3(0., 0., 0.2), radius);
if (nearer(i, hit)) {
  i.material = DEBUG_BLUE;
  i.hit = hit;
}

return i;")),
                in_subspace: Normal,
            ),
        ),
