            name: "mobuis portal",
            data: Complex(
                kind: Portal(Some(Named("mobius_a_final")), Some(Named("mobius_b_final"))),
                intersect: (("//return scene_intersection_none;

SurfaceIntersection hit =  mobius_intersect(r);
int material = portal_blue_M;
if (first) { material = portal_orange_M; }
float y = abs(hit.v);
float black = border_size_u * black_border_size_u/2.;
if (y > 1. - black || y < 1. - border_size_u + black) {
  material = solid_black_M;
}
if (abs(hit.v) < 1. - border_size_u) {
  if (tlight(teleport_light_u)) {
    material = TELEPORT;
  } else {
    material = gray_grid_M;
  }
}
return SceneIntersection(material, hit, false);")),
