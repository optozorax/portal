        (
            name: "object1",
            data: (("SurfaceIntersection intersect_object1(Ray r) {
    SurfaceIntersection hit = plane_intersect(r, identity_mat, vec3(0.)); // we don't care about normal vector
    if (!hit.hit) return intersection_none;

    vec4 pos_local = r.o + r.d * hit.t;

    float u = pos_local.x;
    float v = -pos_local.y;
    bool is_inside = abs(u) < PI && v > 0. && v < PI;

    if (!is_inside) return intersection_none;

    return SurfaceIntersection(true, hit.t, u, v, vec3(0.));
}

vec3 object1_uv(float u, float v) {
    return vec3(u, -v, 0.);
}

mat3 object1_transform_matrix(float u, float v) {
    float offset = 0.01;

    vec3 pos = object1_uv(u, v);

    vec3 du = normalize(object1_uv(u + offset, v) - pos);
    vec3 dv = normalize(object1_uv(u, v  + offset) - pos);
    vec3 dr = cross(du, dv);
    return mat3(dr, dv, du);
}
")),
        ),
        (
            name: "object2",
            data: (("SurfaceIntersection intersect_object2(Ray r) {
    vec3 op = -r.o.xyz;
    float b = dot(op, r.d.xyz);
    float det = b*b - dot(op, op) + 1.0;
    if (det < 0.) return intersection_none;

    det = sqrt(det);
    float t = b - det;
    if (t < 0.) t = b + det;
    if (t < 0.) return intersection_none;

    vec4 pos = r.o + r.d * t;
    
    float u = atan(pos.z, pos.x);
    float v = atan(sqrt(pos.x * pos.x + pos.z * pos.z), pos.y);

    return SurfaceIntersection(true, t, u, v, vec3(0.));
}

vec3 object2_uv(float u, float v) {
    return vec3(cos(u) * sin(v), cos(v), sin(u) * sin(v));
}

mat3 object2_transform_matrix(float u, float v) {
    float offset = 0.01;

    vec3 pos = object2_uv(u, v);

    vec3 du = normalize(object2_uv(u + offset, v) - pos);
    vec3 dv = normalize(object2_uv(u, v  + offset) - pos);
    vec3 dr = cross(du, dv);
    return mat3(dr, dv, du);
}")),
