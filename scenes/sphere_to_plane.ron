        (
            name: "debug_matrix1",
            data: Complex(
                kind: Simple(Some(Named("object1"))),
                intersect: (("if (debug_matrix_u == 0) return scene_intersection_none;

float u = debug_u_u;
float v = debug_v_u;

float radius = 0.06;
float offset = 0.01;

mat3 mat = object1_transform_matrix(u, v);

SurfaceIntersection hit = intersection_none;
SceneIntersection i = SceneIntersection(0, hit, false);

vec3 pos = object1_uv(u, v);

hit = cap(r, pos, pos + mat * vec3(1., 0., 0.), radius); if (nearer(i, hit)) { i.hit = hit; i.material = room_red_M; }
hit = cap(r, pos, pos + mat * vec3(0., 1., 0.), radius); if (nearer(i, hit)) { i.hit = hit; i.material = room_green_M; }
hit = cap(r, pos, pos + mat * vec3(0, 0., 1.), radius); if (nearer(i, hit)) { i.hit = hit; i.material = room_blue_M; }

return i;")),
                in_subspace: Normal,
