                kind: Simple(Some(Named("tr"))),
                is_inside: (("pos.z -= speed_u * (1. - dt_u);
float value = (a_mat_inv * pos).z;
if (value < 0.) return NOT_INSIDE;

int result = is_inside_triangle(x, y, 2.0, 2.0, 0.04, triangle_white_M, triangle_black_M);

if (show_cut_u == 1) {
  if (value < 0.04 && result != NOT_INSIDE) return triangle_black_M;
}

return result;")),
                in_subspace: Normal,
