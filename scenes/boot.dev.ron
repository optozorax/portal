        (
            name: "box6",
            data: (("// Face material mapping (recommended):
//  +X, -X, +Y, -Y, +Z, -Z
SceneIntersection intersect_box6(
    vec3 rad, Ray r,
    int matPX, int matNX,
    int matPY, int matNY,
    int matPZ, int matNZ
) {
  vec3 m = 1.0 / r.d.xyz;
  vec3 n = m * r.o.xyz;
  vec3 k = abs(m) * rad;
  vec3 t1 = -n - k;
  vec3 t2 = -n + k;

  float tN = max(max(t1.x, t1.y), t1.z);
  float tF = min(min(t2.x, t2.y), t2.z);

  if (tN > tF) return scene_intersection_none;
  if (tF < 0.0) return scene_intersection_none;

  bool useExit = (tN < 0.0);
  float t = useExit ? tF : tN;

  // Correct normal for entry vs exit
  vec3 oN = useExit
    ? ( sign(r.d.xyz) * step(t2.xyz, t2.yzx) * step(t2.xyz, t2.zxy) )
    : ( -sign(r.d.xyz) * step(t1.yzx, t1.xyz) * step(t1.zxy, t1.xyz) );

  vec3 pos = (r.o + r.d * t).xyz;

  const float EPS = 1e-4;

  // Default: Z face (same as your default UV case)
  int material = (pos.z > 0.0) ? matPZ : matNZ;
  vec2 uv = vec2(pos.x, pos.y);
  if (pos.z < 0.0) uv.x = -uv.x;

  // X faces override
  if (abs(abs(pos.x) - rad.x) < EPS) {
    material = (pos.x > 0.0) ? matPX : matNX;

    uv = vec2(pos.y, pos.z);
    if (pos.x < 0.0) uv.x = -uv.x;
  }

  // Y faces override (matches your current priority on edges/corners)
  if (abs(abs(pos.y) - rad.y) < EPS) {
    material = (pos.y > 0.0) ? matPY : matNY;

    uv = vec2(pos.x, pos.z);
    if (pos.y > 0.0) uv.x = -uv.x;
  }

  return SceneIntersection(
    material,
    SurfaceIntersection(true, t, uv.x, uv.y, normalize_normal(r.d.xyz, oN)),
    false
  );
}
