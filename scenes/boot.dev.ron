);

mat3 object1_mat_custom = object1_transform_matrix(i.u, i.v);

if (teleport_light_u == 0 || teleport_light_cylinder_u == 0) {
    vec3 normal = adjugate(object1_mat) * object1_mat_custom * vec3(1., 0., 0.);
    return SceneIntersectionWithMaterial(
        SceneIntersection(grid_gray_M, SurfaceIntersection(true, i.t, i.u / PI, i.v / PI, normal), false),
        material_next(vec3(1.), r)
    );
}

mat3 object2_mat_custom = object2_transform_matrix(i.u, i.v);

r.o = vec4(object2_uv(i.u, i.v), 1.);
r.d = vec4(object2_mat_custom * (inverse(object1_mat_custom) * r.d.xyz), 0.);
r = normalize_ray(r);

//if (invert_ray_u == 1) {
//    r.d = -r.d;
//}

r.o += r.d * _offset_after_material;

r = transform(object2_mat, r);
r = normalize_ray(r);

SurfaceIntersection hit = SurfaceIntersection(true, i.t, i.u, i.v, object2_mat_custom * vec3(1., 0., 0.));
return SceneIntersectionWithMaterial(
    SceneIntersection(CUSTOM_MATERIAL, hit, false),
    material_next(vec3(color_mul_u), r)
);"))),
