        (
            name: "common",
            data: (("bool invert_if(bool value, bool condition) {
  if (condition) {
    return !value;
  } else {
    return value;
  }
}")),
        ),
        (
            name: "room",
            data: (("int is_inside_square(float x, float y, float sizex, float sizey, int material) {
  if (abs(x) < sizex && abs(y) < sizey) {
    return material;
  } else {
    return NOT_INSIDE;
  }
}
")),
        ),
        (
            name: "box",
            data: (("SceneIntersection intersect_box(Ray r, int material) {
vec3 rad = vec3(4., 4., 4.);
vec3 m = 1.0/r.d.xyz;
vec3 n = m*r.o.xyz;
vec3 k = abs(m)*rad;
vec3 t1 = -n - k;
vec3 t2 = -n + k;

float tN = max( max( t1.x, t1.y ), t1.z );
float tF = min( min( t2.x, t2.y ), t2.z );

float t = tN;
if (tN < 0.0 && tF > 0.0) t = tF;

if(tN > tF) return scene_intersection_none;

if(t < 0.0) return scene_intersection_none;

vec3 oN = -sign(r.d.xyz)*step(t1.yzx,t1.xyz)*step(t1.zxy,t1.xyz);

vec3 pos = (r.o + r.d * t).xyz;

vec2 uv = vec2(pos.x, pos.y);
if (abs(abs(pos.x) - rad.x) < 0.0001) {
  uv = vec2(pos.y, pos.z);
}
if (abs(abs(pos.y) - rad.y) < 0.0001) {
  uv = vec2(pos.x, pos.z);
}

return SceneIntersection(material, SurfaceIntersection(true, t, uv.x, uv.y, normalize_normal(r.d.xyz, oN)), false);
}")),
        ),
        (
            name: "inverse",
            data: (("mat3 transpose(mat3 matrix) {
    vec3 row0 = matrix[0];
    vec3 row1 = matrix[1];
    vec3 row2 = matrix[2];
    mat3 result = mat3(
        vec3(row0.x, row1.x, row2.x),
        vec3(row0.y, row1.y, row2.y),
        vec3(row0.z, row1.z, row2.z)
    );
    return result;
}

float det(mat2 matrix) {
    return matrix[0].x * matrix[1].y - matrix[0].y * matrix[1].x;
}

mat3 inverse(mat3 matrix) {
    vec3 row0 = matrix[0];
    vec3 row1 = matrix[1];
    vec3 row2 = matrix[2];

    vec3 minors0 = vec3(
        det(mat2(row1.y, row1.z, row2.y, row2.z)),
        det(mat2(row1.z, row1.x, row2.z, row2.x)),
        det(mat2(row1.x, row1.y, row2.x, row2.y))
    );
    vec3 minors1 = vec3(
        det(mat2(row2.y, row2.z, row0.y, row0.z)),
        det(mat2(row2.z, row2.x, row0.z, row0.x)),
        det(mat2(row2.x, row2.y, row0.x, row0.y))
    );
    vec3 minors2 = vec3(
        det(mat2(row0.y, row0.z, row1.y, row1.z)),
        det(mat2(row0.z, row0.x, row1.z, row1.x)),
        det(mat2(row0.x, row0.y, row1.x, row1.y))
    );

    mat3 adj = transpose(mat3(minors0, minors1, minors2));

    return (1.0 / dot(row0, minors0)) * adj;
}")),
        ),
        (
            name: "portal",
            data: (("float circle_distance(float x, float y) {
  return sqrt(sqr(x) + sqr(y));
}

float ellipse_distance(float x, float y) {
  return sqrt(2.*sqr(x) + sqr(y));
}

float square_distance(float x, float y) {
  return max(abs(x), abs(y));
}

float rect_distance(float x, float y, float a, float b) {
  return max(abs(x)-a+1., abs(y)-b+1.);
}

float triangle_distance(float x, float y, float k1, float k2, float y1) {
  return max(
    (y-k1*x)/sqrt(1.0+sqr(k1)),
  max(
    (y-k2*x)/sqrt(1.0+sqr(k2)),
    -y1 * y
  ));
}

int is_inside_object(
  float distance, 
  float size, 
  float border,
  int material_inner, 
  int material_border
) {
  if (distance < size) return material_inner;
  if (distance < size + border) return material_border;
  return NOT_INSIDE;
}

int is_inside_portal(
  float distance, 
  float size, 
  float border,
  float black_border,
  int material_first, 
  int material_second, 
  int grid_material_first, 
  int grid_material_second, 
  bool back,
  bool first
) {
  int material = material_second;
  if (first) { material = material_first; }

  if (distance < size) {
    if (back) {
      return material;      
    } else {
      if (teleport_light_u == 1) {
      	if (mirror_u == 1) {
          return mirror_M;
        } else {
          return TELEPORT;
        }
      } else {
        if (first) {
          return grid_material_first;
        } else {
          return grid_material_second;
        }
      }
    }
  }
  int black_material = solid_black_M;
  if (_black_border_disable == 1) black_material = material;
  if (distance < size + black_border && !back) return black_material;
  if (distance < size + black_border + border) return material;
  if (distance < size + black_border + border + black_border) return black_material;

  return NOT_INSIDE;
}")),
        ),
        (
            name: "wheatley",
            data: (("vec3 rgb(int r, int g, int b) {
  float r1 = float(r) / 255.;
  float g1 = float(g) / 255.;
  float b1 = float(b) / 255.;
  return vec3(r1 * r1, g1 * g1, b1 * b1);
}

float dot_sph_dist(float u, float v, vec3 pos) {
  vec3 pos2 = vec3(
    sin(v*PI)*cos(u*PI),
    sin(v*PI)*sin(u*PI),
    cos(v*PI)
  );
  return dot(pos2, pos);
}

vec3 wheatley_color(float u, float v) {
  float x = sin(v*PI)*cos(u*PI);
  float y = sin(v*PI)*sin(u*PI);
  float z = cos(v*PI);
  vec3 pos = vec3(x, y, z);

  vec3 color = vec3(1.);

  float eye_size = 0.12;
  float white_size = 0.1;
  float light_blue_size = 0.3;
  float blue_size = 0.6;
  float eyelid_size_up = wheatley_up_brow_u;
  float eyelid_size_down = wheatley_down_brow_u;
  float border_size = 0.005;
  float around_eye_size = 0.1;
  float vertical_lines = 0.4;
  float ass_size = 0.2;
  float side_size = 0.75;
  float straps_size = 0.006;
  float side_corner_size = 0.32;

  vec3 white = rgb(255, 255, 255);
  vec3 light_blue = rgb(0, 255, 193);
  vec3 blue = rgb(0, 107, 122);
  vec3 black = rgb(0, 0, 0);
  vec3 gray = rgb(128, 128, 128);
  vec3 dark = rgb(50, 50, 50);
  vec3 darker = rgb(20, 20, 20);

  float eye = v / eye_size;
  if (0. < eye && eye < white_size) color = white;
  eye = (eye - white_size) / (1. - white_size);

  if (0. < eye && eye < light_blue_size) color = mix(white, light_blue, eye/light_blue_size);
  eye = (eye - light_blue_size) / (1. - light_blue_size);

  if (0. < eye && eye < blue_size) color = mix(light_blue, blue, eye/blue_size);
  eye = (eye - blue_size) / (1. - blue_size);

  if (0. < eye && eye < 1.) color = color = mix(blue, black, eye);

  if (v < eye_size && abs(x) < sin(eye_size*PI) && x > sin((eye_size * (1. - eyelid_size_up))*PI)) color = white;

  if (v < eye_size && abs(x) < sin(eye_size*PI) && -x > sin((eye_size * (1. - eyelid_size_down))*PI)) color = white;

  if (v < eye_size && x < sin((eye_size * (1. - eyelid_size_up))*PI) && x > sin((eye_size * (1. - eyelid_size_up) - border_size)*PI)) color = black;

  if (v < eye_size && -x < sin((eye_size * (1. - eyelid_size_down))*PI) && -x > sin((eye_size * (1. - eyelid_size_down) - border_size)*PI)) color = black;

  if (v > eye_size && v < eye_size + border_size) color = black;

  if (v > eye_size + around_eye_size && v < eye_size + border_size + around_eye_size) color = black;

  if (abs(y) < sin(border_size*PI)/2. && v > eye_size && v < eye_size + around_eye_size) color = black;

  if (abs(y) > vertical_lines && abs(y) < vertical_lines + sin(border_size*PI) && v > eye_size + around_eye_size) color = black;

  if (v > 1. - ass_size) {
    color = dark;
    if (abs(x*x) < straps_size || abs(y*y) < straps_size) color = darker;

    if (abs(x - side_corner_size*0.7) < border_size * PI / 2. && -y > side_corner_size*0.7 - border_size * PI/2.) color = black;
    if (abs(-y - side_corner_size*0.7) < border_size * PI / 2. && x > side_corner_size*0.7 - border_size * PI / 2.) color = black;
  }
  if (v > 1. - ass_size && v < 1. - ass_size + border_size) color = black;

  if (abs(y*y) > side_size) {
    color = dark;
    if (abs(x*x) < straps_size || abs(y*y) < straps_size) color = darker;
  }
  if (abs(y*y) > side_size && abs(y*y) < side_size + sin(border_size * PI)) color = black;

  if (v > eye_size && v < eye_size + around_eye_size) {
    if (abs(x - side_corner_size) < border_size * PI / 2. && y > side_corner_size - border_size * PI/2.) color = black;
    if (abs(y - side_corner_size) < border_size * PI / 2. && x > side_corner_size - border_size * PI / 2.) color = black;
  }

  float dot1 = dot_sph_dist(-0.5, -eye_size - around_eye_size/2., pos);
  if (dot1 > 1. - 0.001 && dot1 < 1. - 0.001 + 0.0005) color = black;

  if (dot_sph_dist(0.5, -eye_size - 0.03, pos) > 1. - 0.0005) color = black;
  if (dot_sph_dist(0.57, -eye_size - 0.03, pos) > 1. - 0.0004) color = black;
  if (dot_sph_dist(0.64, -eye_size - 0.03, pos) > 1. - 0.0003) color = black;
  if (dot_sph_dist(0.71, -eye_size - 0.03, pos) > 1. - 0.0002) color = black;
  if (dot_sph_dist(0.78, -eye_size - 0.03, pos) > 1. - 0.0001) color = black;

  return color;
}
")),
        ),
        (
            name: "cylinder",
            data: (("SceneIntersection intersect_cylinder(Ray r, int material) {
  float cylinder_radius = cylinder_radius_u;
  float cylinder_height = cylinder_height_u;

  float a = dot(r.d.xy, r.d.xy);
  float b = 2.0 * dot(r.o.xy, r.d.xy);
  float c = dot(r.o.xy, r.o.xy) - sqr(cylinder_radius);
  float det = b*b - 4.0 * a * c;
  if (det < 0.) return scene_intersection_none;

  det = sqrt(det);

  float t = (-b - det)/(2.*a);
  vec4 pos = r.o + r.d * t;
  float u = atan(pos.y, pos.x) * cylinder_radius;
  float v = pos.z;
  int result_material = NOT_INSIDE;
  if (t > 0. && abs(v) < cylinder_height/2. && u > 0.) {
    result_material = material;
  }

  if (t < 0. || result_material == NOT_INSIDE) {
    t = (-b + det)/(2.*a);
    pos = r.o + r.d * t;
    u = atan(pos.y, pos.x) * cylinder_radius;
    v = pos.z;
    if (t > 0. && abs(v) < cylinder_height/2. && u > 0.) {
      result_material = material;
    }
    if (t < 0. || result_material == NOT_INSIDE) {
      return scene_intersection_none;
    }
  }

  vec3 n = normalize(vec3(pos.xy, 0.));

  return SceneIntersection(result_material, SurfaceIntersection(true, t, u, v, n), false);
}")),
        ),
        (
            name: "object1",
            data: (("SurfaceIntersection intersect_object1(Ray r) {
    SceneIntersection res = intersect_cylinder(r, TELEPORT);
    return res.hit;
}

vec3 object1_uv(float u, float v) {
    return vec3(cylinder_radius_u * cos(u/cylinder_radius_u), cylinder_radius_u * sin(u/cylinder_radius_u), v);
}

mat3 object1_transform_matrix(float u, float v) {
    float offset = 0.001;

    vec3 pos = object1_uv(u, v);

    vec3 du = normalize(object1_uv(u + offset, v) - pos);
    vec3 dv = normalize(object1_uv(u, v  + offset) - pos);
    vec3 dr = -cross(du, dv);
    return mat3(dr, dv, du);
}
")),
        ),
        (
            name: "object2",
            data: (("SurfaceIntersection intersect_object2(Ray r) {
    return intersect_object1(r);
}

vec3 object2_uv(float u, float v) {
    return object1_uv(u, v);
}

mat3 object2_transform_matrix(float u, float v) {
    float offset = 0.001;

    vec3 pos = object2_uv(u, v);

    vec3 du = normalize(object2_uv(u + offset, v) - pos);
    vec3 dv = normalize(object2_uv(u, v  + offset) - pos);
    vec3 dr = cross(du, dv);
    return mat3(dr, dv, du);
}")),
