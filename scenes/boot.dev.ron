                kind: Simple(Some(Inline(Mul(
                    to: Some(Inline(Parametrized(
                        offset: (
                            x: Value(0.0),
                            y: Value(0.0),
                            z: Value(0.0),
                        ),
                        rotate: (
                            x: Uniform(Some(Inline(Formula(("deg2rad(90)*wheatley_side"))))),
