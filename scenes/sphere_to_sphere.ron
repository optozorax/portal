            name: "companion_cube",
            data: (("vec3 companion_cube_color(float u, float v) {
  float mul = 1.;
  float dist = sqrt(u * u + v * v);
  float circle_size = 0.6;
  float circle_border = 0.03;
  if (dist < circle_size + circle_border && dist > circle_size) { mul = 0.4; }
  if (dist > circle_size + circle_border) { mul = (PI + atan(u, v))/(2.0*PI); }

  if (dist < circle_size) {
    float scale = 3.;
    float x = u * scale;
    float y = v * scale + 0.26;
    float temp1 = x*x + y*y - 1.;
    if (temp1 * temp1 * temp1 - x * x * y * y * y < 0.) {
      return vec3(222., 35., 138.) / 255.;
    }
  }

  return color_grid3(vec3(9.176470588235294e-1, 9.176470588235294e-1, 9.176470588235294e-1) * mul, vec2(u + 1., v + 1.));
}")),
