        (
            name: "object1",
            data: (("SurfaceIntersection intersect_object1(Ray r) {
    r = transform(exact_mat_inv, r);
    float len = length(r.d);
    r = normalize_ray(r);

    vec3 op = -r.o.xyz;
    float b = dot(op, r.d.xyz);
    float det = b*b - dot(op, op) + 1.0;
    if (det < 0.) return intersection_none;

    det = sqrt(det);
    float t = b - det;
    vec4 pos = r.o + r.d * t;
    float u = atan(pos.z, pos.x);
    if (t < 0. || (u > 0. && use_half_u == 1)) t = b + det;
    pos = r.o + r.d * t;
    u = atan(pos.z, pos.x);
    if (t < 0. || (u > 0. && use_half_u == 1)) return intersection_none;
    
    float v = atan(sqrt(pos.x * pos.x + pos.z * pos.z), pos.y);

    return SurfaceIntersection(true, t / len, u, v, vec3(0.));
}

vec3 object1_uv(float u, float v) {
    return (exact_mat * vec4(cos(u) * sin(v), cos(v), sin(u) * sin(v), 0.)).xyz;
}

mat3 object1_transform_matrix(float u, float v) {
    float offset = 0.001;

    vec3 pos = object1_uv(u, v);

    vec3 du = normalize(object1_uv(u + offset, v) - pos);
    vec3 dv = normalize(object1_uv(u, v  + offset) - pos);
    vec3 dr = cross(du, dv);
    if (inverse_normal_u == 1) dr = -dr;
    return mat3(dr, dv, du);
}
")),
