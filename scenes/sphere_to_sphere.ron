}

mat3 object2_transform_matrix(float u, float v) {
    float offset = 0.001;

    vec3 pos = object2_uv(u, v);

    vec3 du = normalize(object2_uv(u + offset, v) - pos);
    vec3 dv = normalize(object2_uv(u, v  + offset) - pos);
    vec3 dr = cross(du, dv);
    return mat3(dr, dv, du);
}")),
