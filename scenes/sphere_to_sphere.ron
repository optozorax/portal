        (
            name: "debug_uv1",
            data: Complex(
                kind: Simple(Some(Named("object1"))),
                intersect: (("if (debug_object1_u == 0) return scene_intersection_none;

SurfaceIntersection hit = intersection_none;
SceneIntersection inter = SceneIntersection(room_red_M, hit, false);

// bool is_inside = abs(u) < PI && v > 0. && v < PI;
float u_min = -PI;
float u_max = PI;
float v_min = 0.;
float v_max = PI;
float radius = 0.1;

int size = 10;
for (int i = 0; i < 11; i++) { if (i >= size+1) break; // !FOR_NUMBER!
for (int i = 0; i < size+1; i++) { // !FOR_VARIABLE!
  float u = u_min + float(i)/float(size) * (u_max - u_min);
  for (int j = 0; j < 11; j++) { if (j >= size+1) break; // !FOR_NUMBER!
  for (int j = 0; j < size+1; j++) { // !FOR_VARIABLE!
    float v = v_min + float(j)/float(size) * (v_max - v_min);
hit = cap(r, object1_uv(u, v), object1_uv(u, v), radius); if (nearer(inter, hit)) { inter.hit = hit; }
  }
}

return inter;")),
                in_subspace: Normal,
            ),
        ),
        (
            name: "debug_uv2",
            data: Complex(
                kind: Simple(Some(Named("object2"))),
                intersect: (("if (debug_object2_u == 0) return scene_intersection_none;

SurfaceIntersection hit = intersection_none;
SceneIntersection inter = SceneIntersection(room_blue_M, hit, false);

// bool is_inside = abs(u) < PI && v > 0. && v < PI;
float u_min = -PI;
float u_max = PI;
float v_min = 0.;
float v_max = PI;
float radius = 0.1;

int size = 10;
for (int i = 0; i < 11; i++) { if (i >= size+1) break; // !FOR_NUMBER!
for (int i = 0; i < size+1; i++) { // !FOR_VARIABLE!
  float u = u_min + float(i)/float(size) * (u_max - u_min);
  for (int j = 0; j < 11; j++) { if (j >= size+1) break; // !FOR_NUMBER!
  for (int j = 0; j < size+1; j++) { // !FOR_VARIABLE!
    float v = v_min + float(j)/float(size) * (v_max - v_min);
hit = cap(r, object2_uv(u, v), object2_uv(u, v), radius); if (nearer(inter, hit)) { inter.hit = hit; }
  }
}

return inter;")),
                in_subspace: Normal,
