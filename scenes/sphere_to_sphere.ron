    intersection_materials: ([
        (
            name: "object1_to_object2_portal",
            data: ((("r = transform(object1_mat_inv, r);
float len = length(r.d);
r = normalize_ray(r);
SurfaceIntersection i = intersect_object1(r);
i.t /= len;

mat3 object1_mat_custom = object1_transform_matrix(i.u, i.v);

if (!tlight(teleport_light_u)) {
    vec3 normal = adjugate(object1_mat) * object1_mat_custom * vec3(1., 0., 0.);
